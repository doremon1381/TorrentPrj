<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <!-- Torrent engine -->
    <PackageReference Include="MonoTorrent" Version="3.*" />

    <!-- Google Drive upload + auth -->
    <PackageReference Include="Google.Apis.Drive.v3" Version="1.*" />
    <PackageReference Include="Google.Apis.Auth" Version="1.*" />

    <!-- Generic Host / BackgroundService -->
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="9.*" />

    <!-- CLI verb parsing -->
    <PackageReference Include="System.CommandLine" Version="2.*" />
  </ItemGroup>

</Project>
